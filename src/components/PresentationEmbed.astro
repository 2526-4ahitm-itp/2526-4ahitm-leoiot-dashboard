---
const { slides } = Astro.props;
---
<div class="presentation-shell shell">
  <div class="deck-topbar">
    <a class="button-secondary" href={`${import.meta.env.BASE_URL}`}>Back to site</a>
    <div class="deck-nav">
      {slides.map((slide, index) => (
        <a href={`#slide-${index + 1}`}>{String(index + 1).padStart(2, "0")}</a>
      ))}
      <a href={`#slide-${slides.length + 1}`}>Flow</a>
    </div>
  </div>
  {slides.map((slide, index) => (
    <section class="deck-slide" id={`slide-${index + 1}`}>
      <p class="eyebrow">Slide {String(index + 1).padStart(2, "0")}</p>
      <h2>{slide.title}</h2>
      <p>{slide.body}</p>
    </section>
  ))}
  <section class="deck-slide deck-slide-strong" id={`slide-${slides.length + 1}`}>
    <p class="eyebrow">Operational Flow</p>
    <h2>From sensors to decisions</h2>
    <ul>
      <li>Docker Compose runs the full stack for local demos and development.</li>
      <li>MQTT acts as the central transport for generated and live sensor traffic.</li>
      <li>InfluxDB and Grafana cover storage, history, and visualization.</li>
      <li>GitHub Pages now serves the project site directly at the repository root URL.</li>
    </ul>
  </section>
</div>
