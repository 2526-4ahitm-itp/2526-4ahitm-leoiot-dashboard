---
import Layout from "../components/Layout.astro";
import project from "../data/project.json";
---
<Layout title="LeoIoT Dashboard" description={project.tagline} pathname="/">
  <section class="hero">
    <div class="hero-copy">
      <div>
        <p class="eyebrow">HTL Leonding IoT Platform</p>
        <h1>{project.title}</h1>
        <p class="lede">{project.tagline}</p>
        <div class="hero-actions">
          <a class="button" href={`${import.meta.env.BASE_URL}setup`}>Get Started</a>
          <a class="button-secondary" href={`${import.meta.env.BASE_URL}presentation`}>Open Presentation</a>
          <a class="button-ghost" href={project.repo}>GitHub</a>
        </div>
      </div>
      <div class="chip-row">
        {project.stack.map((item) => <span class="chip">{item}</span>)}
      </div>
    </div>
    <div class="hero-grid">
      <article class="metric-card">
        <strong>10</strong>
        <span>compose services in the end-to-end stack</span>
      </article>
      <article class="metric-card">
        <strong>8</strong>
        <span>simulated rooms documented in the fake sensor package</span>
      </article>
      <article class="metric-card">
        <strong>4</strong>
        <span>main user-facing surfaces: 3D view, dashboard, Grafana, InfluxDB</span>
      </article>
      <article class="metric-card">
        <strong>1</strong>
        <span>shared MQTT backbone for live telemetry</span>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Highlights</p>
        <h2>What the repository already delivers</h2>
      </div>
    </div>
    <div class="cards">
      {project.highlights.map((item) => (
        <article class="panel">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section two-up">
    <figure class="image-card">
      <img src={`${import.meta.env.BASE_URL}project/architektur.png`} alt="Architecture overview" />
      <figcaption>Existing project architecture from the slide deck.</figcaption>
    </figure>
    <article class="panel">
      <p class="eyebrow">Deployment</p>
      <h3>Local runtime and published project docs</h3>
      <p>The repository contains the full classroom telemetry stack, plus a self-hosted deployment workflow for the school VM and a GitHub Pages site for public project documentation.</p>
      <ul>
        {project.deployment.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>
</Layout>
